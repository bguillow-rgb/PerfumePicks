---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import QuickAnswer from '../components/QuickAnswer.astro';
import FAQ from '../components/FAQ.astro';
import Footer from '../components/Footer.astro';
import SoftwareApplicationSchema from '../components/schema/SoftwareApplicationSchema.astro';
import { SITE } from '../consts';

// Latest 3 published articles for the homepage "From the Blog" teaser.
// Drafts are excluded automatically because they have published:false.
const latestArticles = (
  await getCollection('articles', ({ data }) => data.published)
)
  .sort((a, b) => b.data.publishedAt.valueOf() - a.data.publishedAt.valueOf())
  .slice(0, 3);

const quickAnswer =
  'Perfume Picks is an iOS app for fragrance collectors. Catalog every bottle ' +
  'you own, log each wear with the weather and occasion, and get morning picks ' +
  'drawn from your wardrobe — not from a store. A taste profile, cost-per-wear, ' +
  'and an annual Perfume Wrapped recap are built in. Perfume Picks is not a ' +
  'retailer; we never sell fragrance.';

const faqs = [
  {
    q: 'What is Perfume Picks?',
    a:
      'Perfume Picks is an iOS app for fragrance collectors. You catalog your wardrobe, log every wear, and get weather- and occasion-aware picks from the bottles you already own. A taste profile is built from your real collection — not just a quiz.',
  },
  {
    q: 'Is Perfume Picks a retailer?',
    a:
      'No. Perfume Picks does not sell fragrance. When you want to buy a bottle, the app links out to retailers like FragranceX, Sephora, or Amazon Luxury Beauty. We may earn a small commission on those links at no cost to you, and this is disclosed in the Terms.',
  },
  {
    q: 'Is Perfume Picks free? What does Pro unlock?',
    a:
      'The app is free to download. Free gives you the basic taste quiz, a limited daily round of Train My Nose swipes, and a wardrobe of up to twenty bottles. Pro unlocks the full quiz, unlimited swipes, the taste profile screen, advanced analytics, cost-per-wear, and Perfume Wrapped. Pro is monthly or yearly, managed through Apple, and cancelable anytime in iOS Settings.',
  },
  {
    q: 'How does the wear log work?',
    a:
      'Tap a fragrance you wore today and confirm. The app records the date, captures local weather automatically, and asks you for occasion and how many sprays. You can backdate up to two years, log multiple fragrances on the same day for layering experiments, and search wears by season, occasion, or fragrance family later on.',
  },
  {
    q: 'Is my wardrobe data private?',
    a:
      'Yes. Your wardrobe, wear log, ratings, and notes are private by default. Nothing is shared, sold, or used for cross-user ad targeting. Scent of the Day posts become public only when you flip the toggle on a specific entry. See the Privacy Policy for the full breakdown.',
  },
  {
    q: 'Will there be an Android version?',
    a:
      'Perfume Picks launches on iOS first. An Android release is on the roadmap but not yet scheduled.',
  },
  {
    q: 'Why an app instead of a website?',
    a:
      'A wardrobe lives in your pocket. Logging a wear should take three taps from a notification, not a desktop login. The phone also gives us camera-based bottle entry, local weather, and the kind of quick swipe interface that builds a real taste profile over time.',
  },
];
---
<BaseLayout
  title={SITE.name}
  description={SITE.description}
  path="/"
>
  <Fragment slot="head">
    <SoftwareApplicationSchema />
    <link rel="apple-touch-icon" href="/icon.png" />
    <meta property="og:image" content={`${SITE.url}/icon.png`} />
  </Fragment>

  <section class="hero">
    <img src="/icon.png" alt="Perfume Picks app icon" class="hero-icon" width="80" height="80" />
    <h1>{SITE.tagline}</h1>
    <p class="hero-tagline">Catalog your wardrobe. Log every wear.<br/>Wear the bottles you already own.</p>

    <p class="badge">Coming soon to the App Store</p>
    <p class="hero-trust">No ads &middot; Your wardrobe stays yours &middot; iOS first</p>

    <img
      src="/assets/screenshots/wardrobe.png"
      alt="Perfume Picks wardrobe screen showing your fragrance collection organized by status"
      class="hero-shot"
      loading="eager"
      width="280"
    />
  </section>

  <QuickAnswer text={quickAnswer} />

  <section class="features">
    <h2 class="section-title">Built for collectors</h2>

    <div class="feature-grid">
      <div class="feature">
        <div class="feature-icon" aria-hidden="true">&#9826;</div>
        <h3>Your wardrobe, organized</h3>
        <p>Every bottle by house, family, and status &mdash; owned, tried, want, empty. Remaining mL meter and purchase price tracked per bottle.</p>
      </div>

      <div class="feature">
        <div class="feature-icon" aria-hidden="true">&#9998;</div>
        <h3>A wear log that remembers</h3>
        <p>Tap to log. Weather and occasion captured automatically. Backdate up to two years and log layering combinations on the same day.</p>
      </div>

      <div class="feature">
        <div class="feature-icon" aria-hidden="true">&#9788;</div>
        <h3>Picks for tonight, not just shopping</h3>
        <p>Morning pick suggests something from your wardrobe based on weather, occasion, and what you have not worn recently. Wear what you own.</p>
      </div>

      <div class="feature">
        <div class="feature-icon" aria-hidden="true">&#10038;</div>
        <h3>A taste profile from your collection</h3>
        <p>Swipe through scents to refine your profile, then watch it sharpen with every wear you log. Built from real behavior, not a five-question quiz.</p>
      </div>
    </div>

    <p class="features-link"><a href="/features">See every feature &rarr;</a></p>
  </section>

  <h2>How does Perfume Picks make money?</h2>
  <p>
    Perfume Picks is free to download. A Pro subscription unlocks the full
    taste quiz, unlimited Train My Nose swipes, the taste profile screen,
    advanced analytics, and Perfume Wrapped. Some fragrance detail pages also
    include &ldquo;Buy from&rdquo; links to retailers like FragranceX, Sephora,
    and Amazon Luxury Beauty &mdash; we may earn a small commission when you
    use one, at no cost to you. There are no ads and no data selling. We do
    not sell fragrance.
  </p>

  <div class="cta-row">
    {SITE.appStoreUrl ? (
      <a class="btn" href={SITE.appStoreUrl}>Download on iOS</a>
    ) : (
      <span class="btn btn--disabled">App Store — Coming Soon</span>
    )}
  </div>

  {latestArticles.length > 0 && (
    <section class="blog-teaser">
      <h2 class="section-title">From the Blog</h2>
      <ul class="blog-list">
        {latestArticles.map((a) => (
          <li>
            <a href={`/articles/${a.slug}`}>{a.data.title}</a>
            <p>{a.data.description}</p>
          </li>
        ))}
      </ul>
      <p class="features-link"><a href="/articles">All articles &rarr;</a></p>
    </section>
  )}

  <FAQ faqs={faqs} />

  <Footer />
</BaseLayout>
