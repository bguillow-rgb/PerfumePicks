{
  "expo": {
    "name": "Perfume Picks",
    "slug": "perfume-picks",
    "owner": "bg233",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "perfumepicks",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#FAF6F0"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.bobguillow.perfumepicks",
      "appleTeamId": "ZNS5TNLB2D",
      "infoPlist": {
        "NSCameraUsageDescription": "Perfume Picks uses the camera to identify fragrance bottles with the Perfume Concierge.",
        "NSPhotoLibraryUsageDescription": "Perfume Picks needs access to your photo library so you can attach photos to your fragrance wardrobe and profile.",
        "NSPhotoLibraryAddUsageDescription": "Perfume Picks saves wardrobe photos to your library when you choose to keep them.",
        "CFBundleURLTypes": [
          {
            "CFBundleURLSchemes": [
              "REPLACE_WITH_GOOGLE_OAUTH_REVERSED_CLIENT_ID"
            ]
          }
        ],
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#FAF6F0"
      },
      "edgeToEdgeEnabled": true,
      "package": "com.bobguillow.perfumepicks",
      "permissions": []
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-image-picker",
      "expo-secure-store",
      "expo-apple-authentication",
      "expo-font",
      "@react-native-google-signin/google-signin",
      [
        "expo-build-properties",
        {
          "ios": {
            "deploymentTarget": "15.5"
          }
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "45707459-d6b8-4aa8-8ddf-5a5894dde578"
      }
    },
    "updates": {
      "url": "https://u.expo.dev/45707459-d6b8-4aa8-8ddf-5a5894dde578"
    },
    "runtimeVersion": {
      "policy": "appVersion"
    }
  }
}
