EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=your-google-web-client-id
EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=your-google-ios-client-id
EXPO_PUBLIC_REVENUECAT_APPLE_KEY=your-revenuecat-apple-key
# Comped-Pro allowlist now lives in the `comped_users` table (migration 013).
# Seed entries via the Supabase SQL editor — never commit emails to source.
# Anthropic API key is server-side only — set via `npx supabase secrets set ANTHROPIC_API_KEY=...`
# Optional observability — leave empty to disable
EXPO_PUBLIC_SENTRY_DSN=
EXPO_PUBLIC_POSTHOG_API_KEY=
EXPO_PUBLIC_POSTHOG_HOST=
# Local-only — needed for scripts that hit Supabase admin APIs (never ship to client)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
