# Learn more https://docs.github.com/en/get-started/getting-started-with-git/ignoring-files

# dependencies
node_modules/

# Astro content/type cache (marketing site at /web)
.astro/

# Claude Code worktree state — session-local, never commit
.claude/worktrees/

# Expo
.expo/
dist/
web-build/
expo-env.d.ts

# Native
.kotlin/
*.orig.*
*.jks
*.p8
*.p12
*.key
*.mobileprovision

# Metro
.metro-health-check*

# debug
npm-debug.*
yarn-debug.*
yarn-error.*

# macOS
.DS_Store
*.pem

# local env files
.env*.local

# typescript
*.tsbuildinfo

# generated native folders
/ios
/android

# Local build artifacts (not needed in source control)
build/

# Large image datasets (sourced from external storage, not tracked)
scripts/data/adventura-images/
scripts/data/crux-images/
scripts/data/dropbox-images/
scripts/data/fuente-images/
scripts/data/gurkha-images/
scripts/data/padron-images/
