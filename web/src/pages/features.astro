---
import BaseLayout from '../layouts/BaseLayout.astro';
import Footer from '../components/Footer.astro';
import BreadcrumbSchema from '../components/schema/BreadcrumbSchema.astro';
import { SITE } from '../consts';
---
<BaseLayout
  title="Features"
  description="A closer look at Perfume Picks: wardrobe catalog, wear log, taste profile, weather-aware morning picks, cost-per-wear, Perfume Wrapped, and the SOTD feed."
  path="/features"
>
  <Fragment slot="head">
    <BreadcrumbSchema crumbs={[{ name: 'Features', url: `${SITE.url}/features` }]} />
  </Fragment>

  <span class="eyebrow" style="text-align:center;display:block;">{SITE.name}</span>
  <h1>Features</h1>
  <p class="effective">Everything Perfume Picks does, in one place.</p>

  <!-- Morning Pick / Today -->
  <section class="feature-row">
    <div class="feature-row-copy">
      <span class="eyebrow">Morning Pick</span>
      <h3>What should I wear today?</h3>
      <p>The morning pick draws from the bottles you already own. It considers local weather, the occasion you are heading into, the family you have been wearing too much of, and bottles you have not touched in weeks.</p>
      <p>Discovery is fine, but the everyday question is "what do I wear right now?" — and the answer should come from your shelf, not a shopping cart.</p>
    </div>
    <div class="feature-row-shot">
      <img
        src="/assets/screenshots/today.png"
        alt="Perfume Picks Today screen showing a morning wear pick drawn from the user's wardrobe with weather context"
        loading="eager"
        width="260"
      />
    </div>
  </section>

  <!-- Wardrobe -->
  <section class="feature-row feature-row--reverse">
    <div class="feature-row-shot">
      <img
        src="/assets/screenshots/wardrobe.png"
        alt="Wardrobe screen showing fragrances by status — Have, Want, Worn — with mL tracking"
        loading="lazy"
        width="260"
      />
    </div>
    <div class="feature-row-copy">
      <span class="eyebrow">Wardrobe</span>
      <h3>Your collection, perfectly organized</h3>
      <p>Every bottle in one place. Track each fragrance by house, family, and status — <strong>have</strong>, <strong>want</strong>, <strong>worn</strong>, or <strong>tested</strong>. A remaining-mL meter shows how much is left as you log wears.</p>
      <p>Record purchase price per bottle. Filter by season, family, or status. Sort by what you have worn least recently, so the back of the shelf gets its turn.</p>
    </div>
  </section>

  <!-- Train My Nose -->
  <section class="feature-row">
    <div class="feature-row-copy">
      <span class="eyebrow">Taste Profile</span>
      <h3>Train My Nose — built from real behavior</h3>
      <p>A swipe interface presents scents with their notes, families, and houses. Swipe right on what you love, down to bookmark, left to pass. Your profile starts to take shape within a few rounds.</p>
      <p>The profile sharpens with every wear you log. Built from your real collection and your real choices — not from a five-question quiz.</p>
    </div>
    <div class="feature-row-shot">
      <img
        src="/assets/screenshots/train.png"
        alt="Train My Nose swipe interface showing a fragrance card with Pass, Like, and Love actions"
        loading="lazy"
        width="260"
      />
    </div>
  </section>

  <!-- Discover -->
  <section class="feature-row feature-row--reverse">
    <div class="feature-row-shot">
      <img
        src="/assets/screenshots/discover.png"
        alt="Discover screen showing curated edits by mood, celebrity picks, and browse by house"
        loading="lazy"
        width="260"
      />
    </div>
    <div class="feature-row-copy">
      <span class="eyebrow">Discover</span>
      <h3>Find your next bottle</h3>
      <p>Curated edits by mood — Boudoir, Office, Date Night — alongside celebrity favorites and new arrivals. Browse by house, family, or occasion.</p>
      <p>Every fragrance links out to retailers so you can buy when you are ready. No shopping pressure, no algorithmic push — just a well-organized catalog.</p>
    </div>
  </section>

  <!-- Fragrance Detail -->
  <section class="feature-row">
    <div class="feature-row-copy">
      <span class="eyebrow">Fragrance Detail</span>
      <h3>Every note, every wear</h3>
      <p>Tap any fragrance to see its full note pyramid, concentration, release year, and your personal wear history. See the last day you wore it and how it performs across occasions.</p>
      <p>When you are ready to buy, "Buy from" links connect you directly to retailers — with affiliate disclosure right on the page.</p>
    </div>
    <div class="feature-row-shot">
      <img
        src="/assets/screenshots/fragrance-detail.png"
        alt="Fragrance detail page showing The Queen's Room by Perfumehead with note pyramid and wear history"
        loading="lazy"
        width="260"
      />
    </div>
  </section>

  <!-- Cost Per Wear + Wrapped -->
  <section class="feature-row feature-row--reverse">
    <div class="feature-row-shot">
      <img
        src="/assets/screenshots/today-edit.png"
        alt="Today's Edit screen showing curated fragrance picks with new arrivals and trending in your taste"
        loading="lazy"
        width="260"
      />
    </div>
    <div class="feature-row-copy">
      <span class="eyebrow">Analytics</span>
      <h3>Cost-per-wear and Perfume Wrapped</h3>
      <p>Every wear ticks the counter on the bottle's purchase price. The expensive bottle you reach for daily quietly becomes the cheap one. The niche purchase you have worn three times reveals itself.</p>
      <p>At year-end, <strong>Perfume Wrapped</strong> recaps your year — top houses, top families, total wears, layering favorites, and the most-loved bottle by wears per month. Sharable as an image card.</p>
    </div>
  </section>

  <section class="cta-section">
    <h2 class="section-title" style="margin-top:0;">Ready when you are</h2>
    <p class="cta-body">
      Perfume Picks lands on the App Store soon. Questions or feedback?
      Email <a href={`mailto:${SITE.supportEmail}`}>{SITE.supportEmail}</a>.
    </p>
    <div class="cta-row">
      {SITE.appStoreUrl ? (
        <a class="btn" href={SITE.appStoreUrl}>Download on iOS</a>
      ) : (
        <span class="btn btn--disabled">App Store — Coming Soon</span>
      )}
    </div>
  </section>

  <Footer />
</BaseLayout>
