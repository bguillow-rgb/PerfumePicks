{
  "expo": {
    "name": "Stick Picks",
    "slug": "stick-picks",
    "owner": "bg233",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "stickpicks",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0A1A0F"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.stickpicks.app",
      "appleTeamId": "ZNS5TNLB2D",
      "infoPlist": {
        "NSPhotoLibraryUsageDescription": "Stick Picks needs access to your photo library so you can attach photos to journal entries and your profile.",
        "NSPhotoLibraryAddUsageDescription": "Stick Picks saves cigar scan photos to your library when you choose to keep them.",
        "CFBundleURLTypes": [
          {
            "CFBundleURLSchemes": [
              "com.googleusercontent.apps.172292646973-3l3utmm05gcj2nemr9d9r3elf7fr78o7"
            ]
          }
        ],
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#0A1A0F"
      },
      "edgeToEdgeEnabled": true,
      "package": "com.stickpicks.app",
      "permissions": [
        "android.permission.CAMERA"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-image-picker",
      "expo-secure-store",
      "expo-apple-authentication",
      [
        "expo-font",
        {
          "fonts": [
            "./assets/fonts/Cormorant-Variable.ttf",
            "./assets/fonts/Cormorant-Italic-Variable.ttf"
          ]
        }
      ],
      "@react-native-google-signin/google-signin",
      "@sentry/react-native",
      [
        "react-native-vision-camera",
        {
          "cameraPermissionText": "Stick Picks uses your camera to identify cigars by scanning the band.",
          "enableLocation": false,
          "enableCodeScanner": false
        }
      ],
      [
        "expo-build-properties",
        {
          "ios": {
            "deploymentTarget": "15.5"
          }
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "d8ae80f6-93e7-49ee-9299-dc87fabf76f7"
      }
    },
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/d8ae80f6-93e7-49ee-9299-dc87fabf76f7"
    }
  }
}
